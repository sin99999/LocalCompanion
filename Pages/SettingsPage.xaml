<?xml version="1.0" encoding="utf-8" ?>

<Page

    x:Class="LocalCompanion.Pages.SettingsPage"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingsTabScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalScrollMode" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollMode" Value="Auto" />
            <Setter Property="ZoomMode" Value="Disabled" />
        </Style>
        <Style x:Key="SettingsInBorderTextBoxStyle" TargetType="TextBox">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8,12,8" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>
        <Style x:Key="SettingsInBorderComboBoxStyle" TargetType="ComboBox">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8,12,8" />
        </Style>
        <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}" />
        <Style x:Key="SettingsFieldHostStyle" TargetType="StackPanel">
            <Setter Property="Spacing" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="SettingsInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style x:Key="SettingsHintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
        <Style x:Key="SettingsSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SettingsSliderLabelRowStyle" TargetType="Grid">
            <Setter Property="ColumnSpacing" Value="8" />
        </Style>
        <Style x:Key="SettingsTabContentStackStyle" TargetType="StackPanel">
            <Setter Property="Spacing" Value="11" />
            <Setter Property="Padding" Value="0,11,0,24" />
            <Setter Property="MaxWidth" Value="720" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="SettingsTabSectionStackStyle" TargetType="StackPanel">
            <Setter Property="Spacing" Value="7" />
        </Style>
        <Style x:Key="SettingsTabButtonRowStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="7" />
        </Style>
        <!-- Thumb extends past track at min/max; host padding aligns with fields without widening layout. -->
        <Style x:Key="SettingsSliderHostStyle" TargetType="Border">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="SettingsSliderStyle" TargetType="Slider">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="24,16,24,24" Background="{StaticResource CompanionContentBackground}">

        <TabView

            x:Name="SettingsTabs"

            AllowDropTabs="False"

            CanDragTabs="False"

            CanReorderTabs="False"

            CloseButtonOverlayMode="OnPointerOver"

            IsAddTabButtonVisible="False"

            PointerReleased="OnSettingsTabsPointerReleased"

            SelectionChanged="OnSettingsTabSelectionChanged"

            TabDragCompleted="OnSettingsTabDragCompleted"

            TabDragStarting="OnSettingsTabDragStarting">

            <TabViewItem x:Name="GeneralTab" CanDrag="False" Header="{x:Bind ViewModel.UiTabGeneral, Mode=OneWay}" IsClosable="False">

                <ScrollViewer x:Name="GeneralTabScroll" Style="{StaticResource SettingsTabScrollViewerStyle}">

                    <StackPanel Padding="0,11,0,8" Style="{StaticResource SettingsTabContentStackStyle}" Width="{Binding ElementName=GeneralTabScroll, Path=ViewportWidth, Mode=OneWay}">

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiGeneralUserDisplayName, Mode=OneWay}" />

                            <Border Style="{StaticResource SettingsInputBorderStyle}">

                                <TextBox

                                    MaxLength="32"

                                    Style="{StaticResource SettingsInBorderTextBoxStyle}"

                                    Text="{x:Bind ViewModel.UserDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </Border>

                        </StackPanel>

                        <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiGeneralUserDisplayNameHint, Mode=OneWay}" />

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiGeneralFontFamily, Mode=OneWay}" />

                            <Border Style="{StaticResource SettingsInputBorderStyle}">

                                <ComboBox

                                    ItemsSource="{x:Bind ViewModel.ChatFontChoices, Mode=OneWay}"

                                    SelectedItem="{x:Bind ViewModel.SelectedChatFontFamily, Mode=TwoWay}"

                                    MaxDropDownHeight="420"

                                    Style="{StaticResource SettingsInBorderComboBoxStyle}">

                                    <ComboBox.ItemTemplate>

                                        <DataTemplate x:DataType="x:String">

                                            <TextBlock FontFamily="{x:Bind}" Text="{x:Bind}" TextTrimming="CharacterEllipsis" />

                                        </DataTemplate>

                                    </ComboBox.ItemTemplate>

                                </ComboBox>

                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsTabSectionStackStyle}">

                            <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.GeneralChatFontSizeLabel, Mode=OneWay}" />

                            <Border Style="{StaticResource SettingsSliderHostStyle}">
                                <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="12" Maximum="24" StepFrequency="1" Value="{x:Bind ViewModel.GeneralChatFontSize, Mode=TwoWay}" />
                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiGeneralPreview, Mode=OneWay}" />

                            <Border Height="48" Style="{StaticResource SettingsInputBorderStyle}">

                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">

                                    <TextBlock

                                        FontFamily="{x:Bind ViewModel.GeneralPreviewFontFamily, Mode=OneWay}"

                                        FontSize="14"

                                        Padding="12,4,12,4"

                                        RenderTransformOrigin="0,0"

                                        Text="{x:Bind ViewModel.GeneralPreviewText, Mode=OneWay}"

                                        TextWrapping="WrapWholeWords">

                                        <TextBlock.RenderTransform>

                                            <ScaleTransform ScaleX="{x:Bind ViewModel.GeneralPreviewScale, Mode=OneWay}" ScaleY="{x:Bind ViewModel.GeneralPreviewScale, Mode=OneWay}" />

                                        </TextBlock.RenderTransform>

                                    </TextBlock>

                                </ScrollViewer>

                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiGeneralConfirmHistoryDelete, Mode=OneWay}" />

                            <ToggleSwitch
                                OffContent="{x:Bind ViewModel.UiOff, Mode=OneWay}"
                                OnContent="{x:Bind ViewModel.UiOn, Mode=OneWay}"
                                IsOn="{x:Bind ViewModel.ConfirmHistoryDelete, Mode=TwoWay}" />

                        </StackPanel>

                        <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiGeneralConfirmHistoryDeleteHint, Mode=OneWay}" />

                        <StackPanel Style="{StaticResource SettingsTabButtonRowStyle}">

                            <Button

                                Command="{x:Bind ViewModel.SaveGeneralCommand}"

                                Content="{x:Bind ViewModel.UiGeneralSave, Mode=OneWay}"

                                IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}"

                                Style="{StaticResource AccentButtonStyle}" />

                            <Button

                                Command="{x:Bind ViewModel.ResetGeneralCommand}"

                                Content="{x:Bind ViewModel.UiGeneralReset, Mode=OneWay}"

                                IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                        </StackPanel>

                        <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.GeneralStatusText, Mode=OneWay}" TextWrapping="Wrap" Visibility="{x:Bind ViewModel.GeneralStatusVisibility, Mode=OneWay}" />

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiAboutSection, Mode=OneWay}" />

                            <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.AppVersionText, Mode=OneWay}" />

                            <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiAboutPrivacyNote, Mode=OneWay}" />

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsTabButtonRowStyle}">

                            <Button Command="{x:Bind ViewModel.OpenLicensesCommand}" Content="{x:Bind ViewModel.UiAboutLicenses, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                            <Button Command="{x:Bind ViewModel.OpenTroubleshootingCommand}" Content="{x:Bind ViewModel.UiAboutOpenTroubleshooting, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsTabButtonRowStyle}">

                            <Button Command="{x:Bind ViewModel.OpenLogFolderCommand}" Content="{x:Bind ViewModel.UiAboutOpenLogFolder, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                            <Button Command="{x:Bind ViewModel.BackupDataCommand}" Content="{x:Bind ViewModel.UiAboutBackup, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                        </StackPanel>

                        <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.AboutStatusText, Mode=OneWay}" TextWrapping="Wrap" Visibility="{x:Bind ViewModel.AboutStatusVisibility, Mode=OneWay}" />

                </StackPanel>

                </ScrollViewer>

            </TabViewItem>



            <TabViewItem x:Name="ModelTab" CanDrag="False" Header="{x:Bind ViewModel.UiTabModel, Mode=OneWay}" IsClosable="False">

                <ScrollViewer x:Name="ModelTabScroll" Style="{StaticResource SettingsTabScrollViewerStyle}">

                    <StackPanel Style="{StaticResource SettingsTabContentStackStyle}" Width="{Binding ElementName=ModelTabScroll, Path=ViewportWidth, Mode=OneWay}">

                        <InfoBar

                            IsOpen="{x:Bind ViewModel.ModelHasError, Mode=OneWay}"

                            Severity="Error"

                            Title="{x:Bind ViewModel.UiErrorTitle, Mode=OneWay}"

                            Message="{x:Bind ViewModel.ModelErrorText, Mode=OneWay}"

                            Visibility="{x:Bind ViewModel.ModelHasError, Mode=OneWay}" />

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiModelRuntimeStatus, Mode=OneWay}" />

                            <TextBlock

                                Foreground="White"

                                Style="{StaticResource SettingsSectionLabelStyle}"

                                Text="{x:Bind ViewModel.RuntimeHealthText, Mode=OneWay}"

                                TextWrapping="WrapWholeWords" />

                            <TextBlock Style="{StaticResource SettingsHintTextStyle}">
                                <Run Text="{x:Bind ViewModel.UiModelBackend, Mode=OneWay}" /><Run Text=": " /><Run Text="{x:Bind ViewModel.ModelBackendText, Mode=OneWay}" />
                            </TextBlock>

                            <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.ModelLoadProgressVisibility, Mode=OneWay}">

                                <ProgressBar

                                    Height="8"

                                    Maximum="100"

                                    Minimum="0"

                                    Value="{x:Bind ViewModel.ModelLoadProgress, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.ModelLoadStatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.ModelLoadRemainingText, Mode=OneWay}" />

                            </StackPanel>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiModelChatGguf, Mode=OneWay}" />

                            <Border Style="{StaticResource SettingsInputBorderStyle}">

                                <ComboBox

                                    DisplayMemberPath="FileName"

                                    IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}"

                                    ItemsSource="{x:Bind ViewModel.ChatModels, Mode=OneWay}"

                                    SelectedItem="{x:Bind ViewModel.SelectedChatModel, Mode=TwoWay}"

                                    Style="{StaticResource SettingsInBorderComboBoxStyle}" />

                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiModelAdditionalFolder, Mode=OneWay}" />

                            <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.AdditionalModelsFolderDisplayText, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                            <StackPanel Orientation="Horizontal" Spacing="8">

                                <Button Click="OnBrowseModelsFolderClick" Content="{x:Bind ViewModel.UiModelAdditionalFolderBrowse, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                                <Button

                                    Click="OnClearModelsFolderClick"

                                    Content="{x:Bind ViewModel.UiModelAdditionalFolderClear, Mode=OneWay}"

                                    IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}"

                                    Visibility="{x:Bind ViewModel.AdditionalModelsFolderClearVisibility, Mode=OneWay}" />

                            </StackPanel>

                            <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiModelAdditionalFolderHint, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                        </StackPanel>

                        <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiModelMmprojHint, Mode=OneWay}" />

                        <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.MmprojDownloadProgressVisibility, Mode=OneWay}">

                            <ProgressBar

                                Height="8"

                                Maximum="100"

                                Minimum="0"

                                Value="{x:Bind ViewModel.MmprojDownloadProgress, Mode=OneWay}" />

                            <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.MmprojDownloadStatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                        </StackPanel>

                        <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.MmprojStatusText, Mode=OneWay}" />

                        <Button

                            Command="{x:Bind ViewModel.ApplyModelCommand}"

                            Content="{x:Bind ViewModel.UiModelApply, Mode=OneWay}"

                            IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}"

                            Style="{StaticResource AccentButtonStyle}" />

                        <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.ModelStatusText, Mode=OneWay}" TextWrapping="Wrap" />

                    </StackPanel>

                </ScrollViewer>

            </TabViewItem>



            <TabViewItem x:Name="CharacterTab" CanDrag="False" Header="{x:Bind ViewModel.UiTabCharacter, Mode=OneWay}" IsClosable="False">

                <ScrollViewer x:Name="CharacterTabScroll" Style="{StaticResource SettingsTabScrollViewerStyle}">

                    <StackPanel Style="{StaticResource SettingsTabContentStackStyle}" Width="{Binding ElementName=CharacterTabScroll, Path=ViewportWidth, Mode=OneWay}">

                        <InfoBar

                            IsOpen="{x:Bind ViewModel.CharacterHasError, Mode=OneWay}"

                            Severity="Error"

                            Title="{x:Bind ViewModel.UiErrorTitle, Mode=OneWay}"

                            Message="{x:Bind ViewModel.CharacterErrorText, Mode=OneWay}"

                            Visibility="{x:Bind ViewModel.CharacterHasError, Mode=OneWay}" />

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiCharacterRegistered, Mode=OneWay}" />

                            <Border Style="{StaticResource SettingsInputBorderStyle}">

                                <ComboBox

                                    DisplayMemberPath="DisplayName"

                                    ItemsSource="{x:Bind ViewModel.CharacterPresets, Mode=OneWay}"

                                    SelectedItem="{x:Bind ViewModel.SelectedCharacterPreset, Mode=TwoWay}"

                                    Style="{StaticResource SettingsInBorderComboBoxStyle}" />

                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiCharacterName, Mode=OneWay}" />

                            <Border Style="{StaticResource SettingsInputBorderStyle}">

                                <TextBox

                                    Style="{StaticResource SettingsInBorderTextBoxStyle}"

                                    Text="{x:Bind ViewModel.CharacterName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiCharacterPersona, Mode=OneWay}" />

                            <Border

                                Height="{x:Bind ViewModel.CharacterPersonaBoxHeight, Mode=OneWay}"

                                Style="{StaticResource SettingsInputBorderStyle}">

                                <TextBox

                                    AcceptsReturn="True"

                                    Height="{x:Bind ViewModel.CharacterPersonaBoxHeight, Mode=OneWay}"

                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"

                                    ScrollViewer.VerticalScrollBarVisibility="Auto"

                                    Style="{StaticResource SettingsInBorderTextBoxStyle}"

                                    Text="{x:Bind ViewModel.CharacterPersona, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"

                                    TextWrapping="Wrap"

                                    VerticalAlignment="Stretch" />

                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsTabSectionStackStyle}">

                            <Grid Style="{StaticResource SettingsSliderLabelRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.CharacterTemperatureLabel, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiCharacterTemperatureHint, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>

                            <Border Style="{StaticResource SettingsSliderHostStyle}">
                                <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="0" Maximum="2" StepFrequency="0.05" Value="{x:Bind ViewModel.CharacterTemperature, Mode=TwoWay}" />
                            </Border>

                            <Grid Style="{StaticResource SettingsSliderLabelRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.CharacterTopPLabel, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiCharacterTopPHint, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>

                            <Border Style="{StaticResource SettingsSliderHostStyle}">
                                <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="0.05" Maximum="1" StepFrequency="0.05" Value="{x:Bind ViewModel.CharacterTopP, Mode=TwoWay}" />
                            </Border>

                            <Grid Style="{StaticResource SettingsSliderLabelRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.CharacterTopKLabel, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiCharacterTopKHint, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>

                            <Border Style="{StaticResource SettingsSliderHostStyle}">
                                <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="0" Maximum="128" StepFrequency="1" Value="{x:Bind ViewModel.CharacterTopK, Mode=TwoWay}" />
                            </Border>

                            <Grid Style="{StaticResource SettingsSliderLabelRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.CharacterContextLengthLabel, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiCharacterContextLengthHint, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>

                            <Border Style="{StaticResource SettingsSliderHostStyle}">
                                <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="2048" Maximum="262144" StepFrequency="1024" Value="{x:Bind ViewModel.CharacterContextLength, Mode=TwoWay}" />
                            </Border>

                            <Grid Style="{StaticResource SettingsSliderLabelRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.CharacterMaxOutputTokensLabel, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiCharacterMaxOutputTokensHint, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>

                            <Border Style="{StaticResource SettingsSliderHostStyle}">
                                <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="128" Maximum="{x:Bind ViewModel.CharacterMaxOutputTokensSliderMaximum, Mode=OneWay}" StepFrequency="128" Value="{x:Bind ViewModel.CharacterMaxOutputTokens, Mode=TwoWay}" />
                            </Border>

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingsTabButtonRowStyle}">

                            <Button Command="{x:Bind ViewModel.ApplyCharacterDefaultsCommand}" Content="{x:Bind ViewModel.UiApplyCharacterDefaults, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                            <Button Command="{x:Bind ViewModel.SaveCharacterCommand}" Content="{x:Bind ViewModel.UiSave, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />

                            <Button Command="{x:Bind ViewModel.DeleteCharacterCommand}" Content="{x:Bind ViewModel.UiDelete, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                        </StackPanel>

                        <TextBlock MinHeight="24" Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.CharacterStatusText, Mode=OneWay}" TextWrapping="Wrap" />

                    </StackPanel>

                </ScrollViewer>

            </TabViewItem>



            <TabViewItem x:Name="RagTab" CanDrag="False" Header="{x:Bind ViewModel.UiTabRag, Mode=OneWay}" IsClosable="False">

                <ScrollViewer x:Name="RagTabScroll" Style="{StaticResource SettingsTabScrollViewerStyle}">

                    <StackPanel Style="{StaticResource SettingsTabContentStackStyle}" Width="{Binding ElementName=RagTabScroll, Path=ViewportWidth, Mode=OneWay}">

                        <InfoBar

                            IsOpen="{x:Bind ViewModel.RagHasError, Mode=OneWay}"

                            Severity="Error"

                            Title="{x:Bind ViewModel.UiErrorTitle, Mode=OneWay}"

                            Message="{x:Bind ViewModel.RagErrorText, Mode=OneWay}"

                            Visibility="{x:Bind ViewModel.RagHasError, Mode=OneWay}" />

                        <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiRagDescription, Mode=OneWay}" />

                        <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiRagSourceUseHint, Mode=OneWay}" />

                        <TextBlock Style="{StaticResource SettingsSectionLabelStyle}">

                            <Run Text="{x:Bind ViewModel.UiRagChunkCountPrefix, Mode=OneWay}" />

                            <Run Text="{x:Bind ViewModel.RagChunkCount, Mode=OneWay}" />

                        </TextBlock>

                        <StackPanel Style="{StaticResource SettingsTabButtonRowStyle}">

                            <Button x:Name="IngestFileButton" Click="OnIngestFileClick" Content="{x:Bind ViewModel.UiRagIngestFile, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                            <Button x:Name="IngestFolderButton" Click="OnIngestFolderClick" Content="{x:Bind ViewModel.UiRagIngestFolder, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" />

                        </StackPanel>

                        <ListView

                            ItemsSource="{x:Bind ViewModel.RagSources, Mode=OneWay}"

                            MaxHeight="320"

                            SelectionMode="None">

                            <ListView.ItemTemplate>

                                <DataTemplate x:DataType="viewModels:RagSourceRowViewModel" xmlns:viewModels="using:LocalCompanion.ViewModels">

                                    <Grid ColumnSpacing="8" Padding="0,4">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="Auto" />

                                            <ColumnDefinition Width="*" />

                                            <ColumnDefinition Width="Auto" />

                                        </Grid.ColumnDefinitions>

                                        <CheckBox

                                            VerticalAlignment="Center"

                                            Content="{x:Bind EnabledLabel}"

                                            IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />

                                        <StackPanel Grid.Column="1" Spacing="2">

                                            <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />

                                            <TextBlock

                                                Style="{StaticResource CaptionTextBlockStyle}"

                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"

                                                Text="{x:Bind DetailText}" />

                                        </StackPanel>

                                        <Button

                                            Grid.Column="2"

                                            VerticalAlignment="Center"

                                            Click="OnDeleteRagSourceClick"

                                            Content="{x:Bind DeleteLabel}"

                                            Tag="{x:Bind Source}" />

                                    </Grid>

                                </DataTemplate>

                            </ListView.ItemTemplate>

                        </ListView>

                        <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.RagStatusText, Mode=OneWay}" TextWrapping="Wrap" />

                    </StackPanel>

                </ScrollViewer>

            </TabViewItem>



            <TabViewItem x:Name="VoicevoxTab" CanDrag="False" Header="{x:Bind ViewModel.UiTabVoicevox, Mode=OneWay}" IsClosable="False">

                <ScrollViewer x:Name="VoicevoxTabScroll" Style="{StaticResource SettingsTabScrollViewerStyle}">

                    <Grid MinHeight="359" Width="{Binding ElementName=VoicevoxTabScroll, Path=ViewportWidth, Mode=OneWay}">

                        <StackPanel Style="{StaticResource SettingsTabContentStackStyle}">

                            <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiVoicevoxEnabled, Mode=OneWay}" />

                                <ToggleSwitch
                                    OffContent="{x:Bind ViewModel.UiOff, Mode=OneWay}"
                                    OnContent="{x:Bind ViewModel.UiOn, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.VoicevoxEnabled, Mode=TwoWay}" />

                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiVoicevoxAutoSpeak, Mode=OneWay}" />

                                <ToggleSwitch
                                    OffContent="{x:Bind ViewModel.UiOff, Mode=OneWay}"
                                    OnContent="{x:Bind ViewModel.UiOn, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.VoicevoxAutoSpeak, Mode=TwoWay}" />

                            </StackPanel>

                            <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiVoicevoxSpeakInJapanesePronunciation, Mode=OneWay}" />

                                <ToggleSwitch
                                    OffContent="{x:Bind ViewModel.UiOff, Mode=OneWay}"
                                    OnContent="{x:Bind ViewModel.UiOn, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.VoicevoxSpeakInJapanesePronunciation, Mode=TwoWay}" />

                            </StackPanel>

                            <TextBlock Style="{StaticResource SettingsHintTextStyle}" Text="{x:Bind ViewModel.UiVoicevoxSpeakInJapanesePronunciationHint, Mode=OneWay}" />

                            <StackPanel Style="{StaticResource SettingsFieldHostStyle}">

                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Bind ViewModel.UiVoicevoxSpeaker, Mode=OneWay}" />

                                <Border Style="{StaticResource SettingsInputBorderStyle}">

                                    <ComboBox

                                        DisplayMemberPath="DisplayName"

                                        ItemsSource="{x:Bind ViewModel.VoicevoxSpeakers, Mode=OneWay}"

                                        PlaceholderText="{x:Bind ViewModel.UiVoicevoxSpeakerPlaceholder, Mode=OneWay}"

                                        SelectedItem="{x:Bind ViewModel.SelectedVoicevoxSpeaker, Mode=TwoWay}"

                                        Style="{StaticResource SettingsInBorderComboBoxStyle}" />

                                </Border>

                            </StackPanel>

                            <TextBlock

                                Style="{StaticResource SettingsHintTextStyle}"

                                Text="{x:Bind ViewModel.VoicevoxSpeakersStatus, Mode=OneWay}"

                                Visibility="{x:Bind ViewModel.VoicevoxSpeakersStatusVisibility, Mode=OneWay}" />

                            <StackPanel Style="{StaticResource SettingsTabSectionStackStyle}">

                                <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.VoicevoxSpeedScaleLabel, Mode=OneWay}" />

                                <Border Style="{StaticResource SettingsSliderHostStyle}">
                                    <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="0.5" Maximum="2" StepFrequency="0.05" Value="{x:Bind ViewModel.VoicevoxSpeedScale, Mode=TwoWay}" />
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.VoicevoxPitchScaleLabel, Mode=OneWay}" />

                                <Border Style="{StaticResource SettingsSliderHostStyle}">
                                    <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="-0.15" Maximum="0.15" StepFrequency="0.01" Value="{x:Bind ViewModel.VoicevoxPitchScale, Mode=TwoWay}" />
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.VoicevoxIntonationScaleLabel, Mode=OneWay}" />

                                <Border Style="{StaticResource SettingsSliderHostStyle}">
                                    <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="0" Maximum="2" StepFrequency="0.05" Value="{x:Bind ViewModel.VoicevoxIntonationScale, Mode=TwoWay}" />
                                </Border>

                                <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.VoicevoxVolumeScaleLabel, Mode=OneWay}" />

                                <Border Style="{StaticResource SettingsSliderHostStyle}">
                                    <Slider Style="{StaticResource SettingsSliderStyle}" Minimum="0" Maximum="2" StepFrequency="0.05" Value="{x:Bind ViewModel.VoicevoxVolumeScale, Mode=TwoWay}" />
                                </Border>

                            </StackPanel>

                            <Button Command="{x:Bind ViewModel.SaveVoicevoxCommand}" Content="{x:Bind ViewModel.UiVoicevoxSave, Mode=OneWay}" IsEnabled="{x:Bind ViewModel.IsSettingsInputEnabled, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />

                            <TextBlock Style="{StaticResource SettingsSectionLabelStyle}" Text="{x:Bind ViewModel.VoicevoxStatusText, Mode=OneWay}" TextWrapping="Wrap" />

                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,4,2"
                            MaxWidth="360"
                            Spacing="4">
                            <TextBlock
                                x:Name="VoicevoxPoweredByLinkText"
                                HorizontalAlignment="Right"
                                Opacity="0.55"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                TextAlignment="Right"
                                ToolTipService.ToolTip="https://voicevox.hiroshiba.jp/" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Opacity="0.55"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.VoicevoxPoweredByNoteText, Mode=OneWay}"
                                TextAlignment="Right"
                                TextWrapping="Wrap"
                                Visibility="{x:Bind ViewModel.VoicevoxPoweredByNoteVisibility, Mode=OneWay}" />
                        </StackPanel>

                    </Grid>

                </ScrollViewer>

            </TabViewItem>



        </TabView>

    </Grid>

</Page>

