<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LocalCompanion.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LocalCompanion"
    mc:Ignorable="d">
    <Grid Background="{StaticResource CompanionTitleBarBackground}">
        <NavigationView
            x:Name="NavView"
            Background="{StaticResource CompanionTitleBarBackground}"
            CompactPaneLength="52"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="OnNavItemInvoked"
            PaneClosed="OnNavPaneClosed"
            PaneDisplayMode="Left"
            PaneOpened="OnNavPaneOpened"
            SelectionChanged="OnNavSelectionChanged"
            SizeChanged="OnNavViewSizeChanged">
            <NavigationView.PaneCustomContent>
                <Grid Height="52">
                    <Button
                        x:Name="PaneToggleButton"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnPaneToggleClick"
                        Padding="8"
                        ToolTipService.ToolTip="Show or hide sidebar">
                        <PathIcon
                            Width="16"
                            Height="16"
                            Data="M4,4 H11 V20 H4 Z M13,4 H20 V20 H13 Z" />
                    </Button>
                </Grid>
            </NavigationView.PaneCustomContent>

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="ChatNavItem" Content="Chat" Tag="chat">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Message" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem" Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="CharacterNavItem" Content="Character (Default)" Tag="character">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Contact" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    x:Name="LanguageNavItem"
                    Content="Language Settings"
                    SelectsOnInvoked="False"
                    Tag="language">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Globe" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.PaneFooter>
                <Grid x:Name="ConversationHistoryHost" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid
                        x:Name="ConversationHistoryPanel"
                        Grid.Row="1"
                        VerticalAlignment="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="72" />
                        </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Background="Transparent"
                        IsHitTestVisible="False"
                        Opacity="0" />
                    <TextBlock
                        x:Name="ConversationHistoryHeader"
                        Grid.Row="1"
                        Margin="12,0,12,8"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Conversation History"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <ListView
                        x:Name="ThreadList"
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="OnThreadSelected"
                        SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="44" />
                                <Setter Property="Padding" Value="12,8,12,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate
                                x:DataType="services:ConversationThreadPreview"
                                xmlns:services="using:LocalCompanion.Services">
                                <TextBlock
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    Text="{x:Bind Title}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" Background="{StaticResource CompanionContentBackground}" />
        </NavigationView>

        <Grid x:Name="SplashPanel" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <StackPanel
                Width="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="14">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Text="LocalCompanion" />

                <StackPanel x:Name="LanguagePickerPanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="言語を選択してください"
                        TextAlignment="Center" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="Choose your language"
                        TextAlignment="Center" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="表示言語を選んでください。後から左下の Language メニューで変更できます。&#x0a;&#x0a;Choose the display language. You can change it later from the Language menu at the bottom left."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            x:Name="PickJapaneseButton"
                            MinWidth="140"
                            Click="OnPickJapaneseClick"
                            Content="日本語"
                            Style="{StaticResource AccentButtonStyle}" />
                        <Button
                            x:Name="PickEnglishButton"
                            MinWidth="140"
                            Click="OnPickEnglishClick"
                            Content="English" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="FirstRunSetupPanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock
                        x:Name="FirstRunSetupTitleText"
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="FirstRunSetupDescriptionText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="FirstRunSetupOwnModelHintText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="FirstRunSetupFolderText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="FirstRunSetupErrorText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            x:Name="FirstRunContinueButton"
                            MinWidth="180"
                            Click="OnFirstRunContinueClick"
                            Style="{StaticResource AccentButtonStyle}" />
                        <Button
                            x:Name="FirstRunChooseFolderButton"
                            MinWidth="160"
                            Click="OnFirstRunChooseFolderClick" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="StartupProgressPanel" Spacing="14">
                    <TextBlock
                        x:Name="SplashSubtitleText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Starting LocalCompanion…"
                        TextAlignment="Center" />
                    <ProgressBar
                        x:Name="StartupProgressBar"
                        Height="8"
                        IsIndeterminate="True"
                        Maximum="100"
                        Minimum="0" />
                    <TextBlock
                        x:Name="StartupPercentText"
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="StartupStatusText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Please wait…"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
